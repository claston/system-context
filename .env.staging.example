# Staging database (Neon example)
DATABASE_URL=postgresql://<user>:<password>@<host>/<database>?sslmode=require

# MCP hardening for staging
MCP_API_TOKEN=<set-a-random-token>
MCP_TOOL_TIMEOUT_SECONDS=5
MCP_AUDIT_LOG_ENABLED=true
MCP_AUDIT_LOG_INCLUDE_RESULT_BODY=false
MCP_AUDIT_MAX_PAYLOAD_CHARS=4000

# Optional GitHub connector staging settings
GITHUB_TOKEN=<optional>
GITHUB_OWNER=<optional>
GITHUB_REPOS=<optional-comma-separated>
GITHUB_PER_PAGE=20
GITHUB_MAX_PAGES=10
GITHUB_SYNC_LOOKBACK_MINUTES=60

# Optional Render runtime connector staging settings
RENDER_API_KEY=<optional>
RENDER_OWNER_ID=<optional>
RENDER_LOGS_RESOURCE_ID=<optional-srv-id-for-logs-fallback>
RENDER_RUNTIME_ENVIRONMENT=staging
RENDER_TIMEOUT_SECONDS=10
